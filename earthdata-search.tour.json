{
  "id": "earthdata-search-intro",
  "title": "Earthdata Search",
  "description": "Discover how NASA's Earth Science data search platform is built — from React UI to serverless backend.",
  "version": "1.0.0",
  "audience": "New Developers",
  "prerequisites": [
    "Basic understanding of React and serverless architecture"
  ],
  "steps": [
    {
      "id": "welcome",
      "title": "NASA's Data Discovery Platform",
      "description": "Earthdata Search lets scientists find, visualize, and download Earth Science data from NASA's Common Metadata Repository. The frontend lives in static/, the serverless backend in serverless/, and shared logic bridges both.",
      "estimatedTime": 25,
      "focusDirectory": "",
      "colorMode": "fileTypes"
    },
    {
      "id": "react-frontend",
      "title": "React Frontend",
      "description": "98 components power the UI — search results, an interactive map, granule browsing, and data access workflows. Zustand manages state through 21 domain slices, and Apollo Client handles GraphQL queries to the backend.",
      "estimatedTime": 25,
      "focusDirectory": "static/src/js",
      "colorMode": "fileTypes",
      "highlightLayers": [
        {
          "id": "components",
          "name": "UI Components",
          "color": "#3b82f6",
          "items": [
            { "path": "static/src/js/components", "type": "directory" }
          ],
          "opacity": 0.7,
          "renderStrategy": "border"
        },
        {
          "id": "state",
          "name": "State Management",
          "color": "#f59e0b",
          "items": [
            { "path": "static/src/js/zustand", "type": "directory" }
          ],
          "opacity": 0.7,
          "renderStrategy": "border"
        }
      ],
      "interactiveActions": [
        {
          "type": "hover-directory",
          "description": "Hover over the components directory to see the UI building blocks",
          "target": "static/src/js/components"
        }
      ]
    },
    {
      "id": "zustand-store",
      "title": "Zustand State Architecture",
      "description": "Instead of Redux, state is split into 21 focused slices — collections, granules, map, project, query, user, and more. Each slice owns its domain logic with Immer for immutable updates, composed into a single store.",
      "estimatedTime": 25,
      "focusDirectory": "static/src/js/zustand",
      "colorMode": "fileTypes",
      "highlightLayers": [
        {
          "id": "slices",
          "name": "Store Slices",
          "color": "#f59e0b",
          "items": [
            { "path": "static/src/js/zustand/slices", "type": "directory" }
          ],
          "opacity": 0.7,
          "renderStrategy": "border"
        },
        {
          "id": "selectors",
          "name": "Selectors",
          "color": "#10b981",
          "items": [
            { "path": "static/src/js/zustand/selectors", "type": "directory" }
          ],
          "opacity": 0.7,
          "renderStrategy": "border"
        }
      ],
      "interactiveActions": [
        {
          "type": "hover-directory",
          "description": "Hover over slices to see the 21 domain-specific state modules",
          "target": "static/src/js/zustand/slices"
        }
      ]
    },
    {
      "id": "serverless-backend",
      "title": "Serverless Lambda Backend",
      "description": "30+ Lambda functions handle data access orchestration — ordering through CMR, Harmony, and SWODLR services, plus auth via Earthdata Login, shapefile storage, and a GraphQL API that the frontend queries.",
      "estimatedTime": 25,
      "focusDirectory": "serverless/src",
      "colorMode": "fileTypes",
      "highlightLayers": [
        {
          "id": "graphql",
          "name": "GraphQL API",
          "color": "#e535ab",
          "items": [
            { "path": "serverless/src/graphQl", "type": "directory" }
          ],
          "opacity": 0.7,
          "renderStrategy": "border"
        },
        {
          "id": "ordering",
          "name": "Order Processing",
          "color": "#ef4444",
          "items": [
            { "path": "serverless/src/submitCmrOrderingOrder", "type": "directory" },
            { "path": "serverless/src/submitHarmonyOrder", "type": "directory" },
            { "path": "serverless/src/submitSwodlrOrder", "type": "directory" },
            { "path": "serverless/src/retrieveGranuleLinks", "type": "directory" }
          ],
          "opacity": 0.7,
          "renderStrategy": "border"
        }
      ],
      "interactiveActions": [
        {
          "type": "hover-directory",
          "description": "Hover over the GraphQL directory to see the API layer",
          "target": "serverless/src/graphQl"
        }
      ]
    },
    {
      "id": "multi-tenant-portals",
      "title": "Multi-Tenant Portal System",
      "description": "One codebase powers 25+ portals — PODAAC, GHRC, ORNL DAAC, and more. Each portal config customizes branding, default search params, and feature toggles, letting data centers offer tailored search experiences from shared code.",
      "estimatedTime": 20,
      "focusDirectory": "portals",
      "colorMode": "fileTypes",
      "interactiveActions": [
        {
          "type": "explore",
          "description": "Explore the different portal configurations"
        }
      ]
    },
    {
      "id": "full-picture",
      "title": "The Full Picture",
      "description": "React frontend, serverless backend, shared utilities, CDK infrastructure, and a portal system — all composing NASA's primary Earth Science data discovery tool serving thousands of researchers worldwide.",
      "estimatedTime": 20,
